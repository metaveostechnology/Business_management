{
    "info": {
        "name": "Company Management API — Full Field Test",
        "description": "Tests all fields: id, slug, code, name, legal_name, email, phone, website, tax_number, registration_number, currency_code, timezone, address_line1, address_line2, city, state, country, postal_code, logo_path, is_active, created_at, updated_at",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "base_url", "value": "http://127.0.0.1:8000/api", "type": "string" },
        { "key": "token",    "value": "",                           "type": "string" },
        { "key": "company_slug", "value": "",                      "type": "string" }
    ],
    "item": [
        {
            "name": "STEP 0 — Register Company User",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Registration success', function() { pm.response.to.have.status(201); });"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Accept",       "value": "application/json" },
                    { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"companyadmin@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}"
                },
                "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] }
            }
        },
        {
            "name": "STEP 1 — Company Login",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var json = pm.response.json();",
                            "pm.test('Login success', function() { pm.response.to.have.status(200); });",
                            "if (json.success && json.token) {",
                            "    pm.collectionVariables.set('token', json.token);",
                            "    console.log('✅ Token saved:', json.token);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Accept",       "value": "application/json" },
                    { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"companyadmin@example.com\",\n    \"password\": \"password123\"\n}"
                },
                "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
            }
        },
        {
            "name": "STEP 2 — Create Company (ALL FIELDS)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var json = pm.response.json();",
                            "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
                            "pm.test('success = true', function() { pm.expect(json.success).to.be.true; });",
                            "",
                            "// Save slug for later requests",
                            "if (json.data && json.data.slug) {",
                            "    pm.collectionVariables.set('company_slug', json.data.slug);",
                            "    console.log('✅ Company slug saved:', json.data.slug);",
                            "}",
                            "",
                            "// Assert ALL fields are present in response",
                            "var fields = ['slug','code','name','legal_name','email','phone','website',",
                            "    'tax_number','registration_number','currency_code','timezone',",
                            "    'address_line1','address_line2','city','state','country',",
                            "    'postal_code','logo_path','is_active','created_at','updated_at'];",
                            "",
                            "fields.forEach(function(field) {",
                            "    pm.test('Field present: ' + field, function() {",
                            "        pm.expect(json.data).to.have.property(field);",
                            "    });",
                            "});",
                            "",
                            "// Assert specific field values",
                            "pm.test('slug auto-generated',          function() { pm.expect(json.data.slug).to.equal('infosys-ltd'); });",
                            "pm.test('code = INFY',                  function() { pm.expect(json.data.code).to.equal('INFY'); });",
                            "pm.test('name = Infosys Ltd',           function() { pm.expect(json.data.name).to.equal('Infosys Ltd'); });",
                            "pm.test('legal_name correct',           function() { pm.expect(json.data.legal_name).to.equal('Infosys Limited'); });",
                            "pm.test('email correct',                function() { pm.expect(json.data.email).to.equal('info@infosys.com'); });",
                            "pm.test('phone = 9876543210',           function() { pm.expect(json.data.phone).to.equal('9876543210'); });",
                            "pm.test('website correct',              function() { pm.expect(json.data.website).to.equal('https://infosys.com'); });",
                            "pm.test('tax_number correct',           function() { pm.expect(json.data.tax_number).to.equal('GSTIN123456'); });",
                            "pm.test('registration_number correct',  function() { pm.expect(json.data.registration_number).to.equal('REG123456'); });",
                            "pm.test('currency_code = INR',          function() { pm.expect(json.data.currency_code).to.equal('INR'); });",
                            "pm.test('timezone correct',             function() { pm.expect(json.data.timezone).to.equal('Asia/Kolkata'); });",
                            "pm.test('address_line1 correct',        function() { pm.expect(json.data.address_line1).to.equal('Electronics City, Phase 1'); });",
                            "pm.test('address_line2 correct',        function() { pm.expect(json.data.address_line2).to.equal('Near Wipro Gate'); });",
                            "pm.test('city = Bangalore',             function() { pm.expect(json.data.city).to.equal('Bangalore'); });",
                            "pm.test('state = Karnataka',            function() { pm.expect(json.data.state).to.equal('Karnataka'); });",
                            "pm.test('country = India',              function() { pm.expect(json.data.country).to.equal('India'); });",
                            "pm.test('postal_code = 560100',         function() { pm.expect(json.data.postal_code).to.equal('560100'); });",
                            "pm.test('logo_path correct',            function() { pm.expect(json.data.logo_path).to.equal('logos/infosys.png'); });",
                            "pm.test('is_active = true',             function() { pm.expect(json.data.is_active).to.be.true; });",
                            "pm.test('created_at present',          function() { pm.expect(json.data.created_at).to.not.be.null; });",
                            "pm.test('updated_at present',          function() { pm.expect(json.data.updated_at).to.not.be.null; });"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Accept",        "value": "application/json" },
                    { "key": "Content-Type",  "value": "application/json" },
                    { "key": "Authorization", "value": "Bearer {{token}}" }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Infosys Ltd\",\n    \"code\": \"INFY\",\n    \"legal_name\": \"Infosys Limited\",\n    \"email\": \"info@infosys.com\",\n    \"phone\": \"9876543210\",\n    \"website\": \"https://infosys.com\",\n    \"tax_number\": \"GSTIN123456\",\n    \"registration_number\": \"REG123456\",\n    \"currency_code\": \"INR\",\n    \"timezone\": \"Asia/Kolkata\",\n    \"address_line1\": \"Electronics City, Phase 1\",\n    \"address_line2\": \"Near Wipro Gate\",\n    \"city\": \"Bangalore\",\n    \"state\": \"Karnataka\",\n    \"country\": \"India\",\n    \"postal_code\": \"560100\",\n    \"logo_path\": \"logos/infosys.png\",\n    \"is_active\": 1\n}"
                },
                "url": { "raw": "{{base_url}}/companies", "host": ["{{base_url}}"], "path": ["companies"] }
            }
        },
